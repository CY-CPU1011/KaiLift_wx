/* 「我的」页（design §6.5）。像素风：纯色底（统一 --bg-page，无角落装饰）。仅 rpx + token。 */
/* 不设背景：全局 page 已是 --bg-page，保持四个 tab 页背景完全一致 */
.profile {
  min-height: 100vh;
  box-sizing: border-box;
}

/* 卡片/组件区块统一左右安全边距（与 page-header、sec-head 同为 --sp-4） */
.block {
  margin: 0 var(--sp-4) var(--sp-3);
}

/* —— 资料卡（像素方块） —— */
.profile-card {
  display: flex;
  align-items: center;
  padding: var(--sp-3);
  background: var(--bg-mint);
}

/* 左：像素头像 + 编辑角标 */
.pc__avatar {
  position: relative;
  flex: none;
  width: 132rpx;
  height: 132rpx;
}
.pc__avatar-img {
  width: 132rpx;
  height: 132rpx;
  box-sizing: border-box;
  background: var(--surface);
  border: var(--px-border);
  border-radius: var(--px-radius);
  image-rendering: pixelated;
}
.pc__edit {
  position: absolute;
  right: -8rpx;
  bottom: -8rpx;
  width: 48rpx;
  height: 48rpx;
  box-sizing: border-box;
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--c-primary);
  border: var(--px-border);
  border-radius: var(--px-radius);
}
.pc__edit-img {
  width: 28rpx;
  height: 28rpx;
  image-rendering: pixelated;
}

/* 中：昵称 + Lv. + EXP + 进度条 */
.pc__main {
  flex: 1;
  min-width: 0;
  margin: 0 var(--sp-3);
}
.pc__name-row {
  display: flex;
  align-items: center;
}
.pc__name {
  font-size: 38rpx;
  font-weight: 800;
  color: var(--text-1);
  max-width: 220rpx;
  overflow: hidden;
  white-space: nowrap;
  text-overflow: ellipsis;
}
.pc__lv {
  margin-left: var(--sp-2);
  flex: none;
  padding: 2rpx 12rpx;
  background: var(--c-primary);
  color: var(--text-on);
  font-size: 24rpx;
  font-weight: 800;
  border: var(--px-border);
  border-radius: var(--px-radius);
}
.pc__exp-row {
  display: flex;
  align-items: center;
  margin-top: var(--sp-2);
}
.pc__exp-star {
  width: 30rpx;
  height: 30rpx;
  margin-right: 8rpx;
  image-rendering: pixelated;
}
.pc__exp-text {
  font-size: 24rpx;
  font-weight: 700;
  color: var(--text-2);
}
.pc__bar {
  display: block;
  margin-top: var(--sp-2);
}

/* 右：段位奖牌 */
.pc__trophy {
  position: relative;
  flex: none;
  width: 96rpx;
  height: 96rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}
.pc__trophy-img {
  width: 96rpx;
  height: 96rpx;
  image-rendering: pixelated;
}

.login-cta {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: var(--sp-3);
  padding: var(--sp-3);
  background: var(--surface);
}
.login-cta__main {
  flex: 1;
  min-width: 0;
}
.login-cta__title {
  display: block;
  font-size: 30rpx;
  font-weight: 800;
  color: var(--text-1);
}
.login-cta__sub {
  display: block;
  margin-top: var(--sp-1);
  font-size: 24rpx;
  color: var(--text-3);
}
.login-cta__btn {
  flex: none;
  width: 188rpx;
  height: 72rpx;
  line-height: 72rpx;
  padding: 0;
  box-sizing: border-box;
  background: var(--c-primary);
  color: var(--text-on);
  border: var(--px-border);
  border-radius: var(--px-radius);
  box-shadow: var(--px-shadow);
  font-size: 28rpx;
  font-weight: 800;
}
.login-cta__btn--press {
  box-shadow: var(--px-shadow-press);
  transform: translate(4rpx, 4rpx);
}

/* —— 累计三卡 —— */
.overview {
  display: flex;
  gap: var(--sp-2);
}
.overview__item {
  flex: 1;
  min-width: 0;
}

/* —— 区块标题行（带「查看全部」） —— */
.sec-head {
  display: flex;
  align-items: baseline;
  justify-content: space-between;
  margin: var(--sp-3) var(--sp-4) var(--sp-2);
}
.sec-head__title {
  font-size: 34rpx;
  font-weight: 800;
  color: var(--text-1);
}
/* 成就墙已点亮计数（标题旁小字） */
.sec-head__count {
  margin-left: var(--sp-2);
  font-size: 24rpx;
  font-weight: 700;
  color: var(--c-primary-strong);
}
.sec-head__more {
  font-size: 26rpx;
  font-weight: 600;
  color: var(--c-primary-strong);
}

/* —— 成就墙 —— */
/* 横向 scroll-view 不会按内容自动撑高，须显式给高度，否则徽章会被纵向裁切。
   高度 = 徽章底盘 132rpx（含硬阴影 6rpx）+ 标题（margin 16rpx + 行高 ≈34rpx）。 */
.badges {
  display: flex;
  white-space: nowrap;
  width: 100%;
  height: 200rpx;
  box-sizing: border-box;
}
.badges__item {
  flex: none;
  margin-right: var(--sp-2);
}
.badges__item:last-child {
  margin-right: 0;
}
/* 成就数据未同步时的占位 */
.badges-empty {
  height: 200rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
  color: var(--text-3);
}

/* —— 设置（像素卡，整体描边 + 行间分隔线） —— */
.settings {
  overflow: hidden;
  padding: 0;
}
.settings__row--sep {
  border-bottom: var(--px-border);
}

/* 底部留白：避让固定的自定义 tabBar（高度 + 安全区），与其它 tab 页一致 */
.profile__pad {
  height: calc(160rpx + env(safe-area-inset-bottom));
}

/* —— 编辑资料 sheet（像素化） —— */
.sheet-mask {
  position: fixed;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  background: rgba(20, 29, 31, 0.45);
  display: flex;
  align-items: flex-end;
  /* 高于固定 tabBar（z-index:1000），确保编辑面板完整盖住 tabBar 不被遮挡 */
  z-index: 1200;
}
.sheet {
  width: 100%;
  box-sizing: border-box;
  background: var(--surface);
  border-top: var(--px-border);
  border-radius: var(--px-radius) var(--px-radius) 0 0;
  padding: var(--sp-4) var(--sp-4) calc(env(safe-area-inset-bottom) + var(--sp-4));
}
.sheet__title {
  font-size: 34rpx;
  font-weight: 800;
  color: var(--text-1);
  text-align: center;
  margin-bottom: var(--sp-4);
}
.sheet__avatar {
  display: block;
  width: 160rpx;
  height: 160rpx;
  margin: 0 auto var(--sp-3);
  padding: 0;
  box-sizing: border-box;
  border: var(--px-border);
  border-radius: var(--px-radius);
  box-shadow: var(--px-shadow);
  overflow: hidden;
}
.sheet__avatar-img {
  width: 100%;
  height: 100%;
  image-rendering: pixelated;
}
.sheet__avatar-ph {
  width: 100%;
  height: 100%;
  background: var(--c-primary-soft);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}
.sheet__plus {
  font-size: 48rpx;
  color: var(--c-primary-strong);
  line-height: 1;
}
.sheet__hint {
  margin-top: var(--sp-1);
  font-size: 24rpx;
  color: var(--text-3);
}
.sheet__field {
  background: var(--surface);
  border: var(--px-border);
  border-radius: var(--px-radius);
  padding: 0 var(--sp-3);
  margin-bottom: var(--sp-4);
}
.sheet__input {
  height: 84rpx;
  font-size: 30rpx;
  color: var(--text-1);
}
.sheet__ph {
  color: var(--text-3);
}
.sheet__actions {
  display: flex;
  gap: var(--sp-3);
}
.sheet__btn {
  flex: 1;
  height: 84rpx;
  line-height: 84rpx;
  text-align: center;
  font-size: 30rpx;
  font-weight: 700;
  box-sizing: border-box;
  border: var(--px-border);
  border-radius: var(--px-radius);
  box-shadow: var(--px-shadow);
}
.sheet__btn--press {
  box-shadow: var(--px-shadow-press);
  transform: translate(4rpx, 4rpx);
}
.sheet__btn--ghost {
  background: var(--surface);
  color: var(--text-2);
}
.sheet__btn--primary {
  background: var(--c-primary);
  color: var(--text-on);
}
