<view class="page-bg login">
  <!-- 角落像素装饰（与首页统一：低饱和、置底、不接事件） -->
  <image class="deco deco--cloud-tr" src="/images/ui/decoration/ui_decoration_cloud_top_right.png" mode="aspectFit"></image>
  <image class="deco deco--cloud-tc" src="/images/ui/decoration/ui_decoration_cloud_top_center.png" mode="aspectFit"></image>
  <image class="deco deco--land-bl" src="/images/ui/decoration/ui_decoration_landscape_bottom_left.png" mode="aspectFit"></image>
  <image class="deco deco--land-br" src="/images/ui/decoration/ui_decoration_landscape_bottom_right.png" mode="aspectFit"></image>

  <!-- 状态栏留白（自定义导航栏） -->
  <view style="height:{{statusBarHeight}}px;"></view>

  <!-- 品牌 Hero 区：薄荷像素方块 + 举铁角色 -->
  <view class="hero">
    <view class="hero__art">
      <image class="hero__char" src="/images/characters/male_celebrating.png" mode="aspectFit"></image>
    </view>
    <view class="hero__brand">开练 KaiLift</view>
    <view class="hero__slogan">练完一组，说一句就记了</view>
  </view>

  <!-- 登录 / 注册区 -->
  <view class="panel">
    <button
      class="btn-px"
      hover-class="btn-px--press"
      loading="{{logging}}"
      disabled="{{logging}}"
      bindtap="onLogin"
    >
      <image class="btn-px__mic" src="/images/ui/icons/ui_icon_microphone.png" mode="aspectFit"></image>
      <text class="btn-px__label">微信一键登录</text>
    </button>
    <view class="link" hover-class="link--press" bindtap="onExplore">先看看首页</view>
  </view>
</view>
