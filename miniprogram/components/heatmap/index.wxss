/* 贡献图 —— 像素风（design §6.4 / §2.2）：方角格子、硬描边图例、5 档绿。 */
.hm { width: 100%; }

.hm__scroll { width: 100%; }
.hm__inner { display: inline-block; padding-bottom: 4rpx; }

/* 月份标签：让出左侧 weekday 列（宽 32rpx + 间距 8rpx = 40rpx） */
.hm__months {
  display: flex;
  margin-left: 40rpx;
  margin-bottom: var(--sp-1);
}
.hm__month {
  width: 28rpx;
  margin-right: 8rpx;
  font-size: 20rpx;
  font-weight: 600;
  color: var(--text-2);
  white-space: nowrap;
}

.hm__grid-wrap { display: flex; }
.hm__weekdays {
  display: flex;
  flex-direction: column;
  margin-right: var(--sp-1);
}
.hm__weekday {
  width: 32rpx;
  height: 28rpx;
  margin-bottom: 8rpx;
  font-size: 20rpx;
  line-height: 28rpx;
  color: var(--text-2);
}

.hm__grid { display: flex; }
.hm__col {
  display: flex;
  flex-direction: column;
  margin-right: 8rpx;
}

/* 像素格：方角 + 细描边，无训练=浅灰 */
.hm__cell {
  width: 28rpx;
  height: 28rpx;
  margin-bottom: 8rpx;
  box-sizing: border-box;
  border: 2rpx solid rgba(43, 43, 43, 0.12);
  border-radius: 4rpx;            /* 像素小方角，不用大圆角 */
  background: #E4E8E8;            /* 无训练浅灰 */
  image-rendering: pixelated;
}

/* 5 档绿（无训练 → 深绿）；像素风用实心色阶不用 opacity 渐隐 */
.hm__cell--lv0 { background: #E4E8E8; }
.hm__cell--lv1 { background: #BFE9CC; }
.hm__cell--lv2 { background: #7CD79A; }
.hm__cell--lv3 { background: var(--c-primary); }
.hm__cell--lv4 { background: var(--c-primary-strong); }

/* 越界占位（上一年末/下一年初）：透明、不可点 */
.hm__cell--blank {
  background: transparent;
  border-color: transparent;
}

/* 当天：金描边加粗 */
.hm__cell--today {
  border: 3rpx solid var(--c-amber);
}

.hm__empty {
  padding: var(--sp-5) 0;
  text-align: center;
  font-size: 26rpx;
  color: var(--text-3);
}

/* 图例：每档一格 + 文案 */
.hm__legend {
  display: flex;
  flex-wrap: wrap;
  align-items: center;
  gap: var(--sp-2);
  margin-top: var(--sp-3);
  margin-left: 40rpx;          /* 与网格左缘对齐：让出「周几」标签列（32rpx + 8rpx） */
}
.hm__legend-item {
  display: flex;
  align-items: center;
}
.hm__legend-cell {
  margin: 0 6rpx 0 0;
}
.hm__legend-text {
  font-size: 20rpx;
  color: var(--text-2);
}
