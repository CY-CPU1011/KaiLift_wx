/* 趋势折线（design §6.4）★ 像素风：网格底 + 方块数据点 + 折线段。 */
.tc { width: 100%; }
.tc__head {
  display: flex;
  align-items: baseline;
  justify-content: space-between;
  margin-bottom: var(--sp-3);
}
.tc__title { font-size: 32rpx; font-weight: 700; color: var(--text-1); }
.tc__unit { font-size: 24rpx; font-weight: 400; color: var(--text-3); }
.tc__delta {
  font-size: 22rpx;
  font-weight: 700;
  color: var(--c-primary-strong);
  padding: 2rpx 10rpx;
  background: var(--c-primary-soft);
  border: var(--px-border);
  border-radius: 8rpx;
}

.tc__plot {
  position: relative;
  width: 100%;
  box-sizing: border-box;
  /* 像素网格盒：描边方块底 */
  border: var(--px-border);
  border-radius: var(--px-radius);
  background: var(--bg-mint);
  overflow: hidden;
}

/* 像素网格横线 */
.tc__grid {
  position: absolute;
  inset: 0;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  padding: 12rpx 0;
  box-sizing: border-box;
}
.tc__gridline {
  height: 2rpx;
  background: rgba(43, 43, 43, 0.10);
}

.tc__seg {
  position: absolute;
  height: 5rpx;
  background: var(--c-primary-strong);
  transform-origin: left center;
}
/* 数据点（方块像素点） */
.tc__dot {
  position: absolute;
  width: 16rpx;
  height: 16rpx;
  margin-left: -8rpx;
  margin-top: -8rpx;
  background: var(--c-primary-strong);
  border: 3rpx solid var(--c-ink);
  box-sizing: border-box;
}
/* 末点放大高亮（绿底白心方块） */
.tc__dot--last {
  width: 26rpx;
  height: 26rpx;
  margin-left: -13rpx;
  margin-top: -13rpx;
  background: var(--c-primary);
  border: 4rpx solid var(--c-ink);
}
.tc__empty {
  position: absolute;
  top: 50%;
  left: 0;
  right: 0;
  transform: translateY(-50%);
  text-align: center;
  font-size: 26rpx;
  color: var(--text-3);
}

.tc__xaxis {
  display: flex;
  justify-content: space-between;
  margin-top: var(--sp-2);
}
.tc__xlabel {
  flex: 1;
  text-align: center;
  font-size: 20rpx;
  color: var(--text-2);
}
