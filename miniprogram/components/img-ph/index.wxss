.img-ph { display: inline-flex; overflow: hidden; }
.img-ph__img { width: 100%; height: 100%; }
.img-ph__ph {
  width: 100%; height: 100%;
  display: flex; align-items: center; justify-content: center;
  background: rgba(110, 115, 120, 0.10);
  border: 1rpx dashed rgba(110, 115, 120, 0.25);
  box-sizing: border-box;
}
.img-ph__label {
  font-size: 22rpx; color: var(--text-3); text-align: center; padding: 4rpx;
}
